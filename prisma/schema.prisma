generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// NextAuth Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// App Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // iMoD specific fields
  department    String?   @default("content-it")
  role          String    @default("member")
  jobTitle      String?
  managerId     String?
  // birthDate     DateTime?  // TODO: Add after migration
  // startDate     DateTime?  // TODO: Add after migration
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  activities    Activity[]
  leads         Lead[]
  projects      ProjectAssignment[]
}

model Activity {
  id          String   @id @default(cuid())
  userId      String
  type        String   // article, video, shooting, editing, sales, meeting, other
  title       String
  description String?
  metadata    String?  // JSON string for extra data
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model NewsItem {
  id          String   @id @default(cuid())
  
  // From Google Sheet
  sheetRowId  Int?     @unique  // Original row index from sheet
  date        String?            // Date from sheet (YYYY-MM-DD)
  time        String?            // Time from sheet (HH:MM)
  source      String             // News source (e.g., 9to5Mac)
  category    String             // Category (e.g., Apple, EV)
  title       String
  sourceUrl   String
  summary     String?
  selectedBy  String?            // Who added to sheet
  team        String?            // it/ev
  
  // Portal fields
  status      String   @default("available") // available, claimed, drafting, published
  claimedBy   String?            // User who claimed
  claimedAt   DateTime?
  draftUrl    String?            // WordPress draft URL
  publishedUrl String?           // Published article URL
  publishedAt DateTime?
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([date])
  @@index([team])
}

model Lead {
  id           String    @id @default(cuid())
  companyName  String
  contactName  String
  contactEmail String?
  contactPhone String?
  status       String    @default("new") // new, contacted, proposal, negotiation, won, lost
  value        Float?
  notes        String?
  nextFollowUp DateTime?
  assignedTo   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignee     User      @relation(fields: [assignedTo], references: [id])

  @@index([assignedTo])
  @@index([status])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("backlog") // backlog, in-progress, review, done
  dueDate     DateTime?
  driveLink   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ProjectAssignment[]

  @@index([status])
}

model ProjectAssignment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      String   @default("member") // lead, member
  
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

// ========== Comments & Feedback ==========

model Comment {
  id           String   @id @default(cuid())
  
  targetType   String   // news, draft, article, task
  targetId     String   // ID of the target
  
  authorId     String   // Discord ID or user ID
  authorName   String
  content      String
  
  parentId     String?  // For replies
  
  mentions     String?  // JSON array of mentioned user IDs
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([targetType, targetId])
  @@index([authorId])
  @@index([parentId])
}

// ========== Audit Log ==========

model AuditLog {
  id           String   @id @default(cuid())
  
  userId       String
  userName     String
  
  action       String   // create, update, delete, claim, publish, approve, reject
  targetType   String   // news, draft, leave, asset, etc.
  targetId     String?
  targetTitle  String?
  
  details      String?  // JSON string with additional details
  ipAddress    String?
  userAgent    String?
  
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}

// ========== Templates ==========

model Template {
  id           String   @id @default(cuid())
  
  name         String
  type         String   // intro, conclusion, style, snippet
  category     String?  // Apple, EV, AI, etc.
  
  content      String
  variables    String?  // JSON array of variables like {{title}}, {{source}}
  
  authorId     String?
  authorName   String?
  
  isPublic     Boolean  @default(true)
  usageCount   Int      @default(0)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([category])
}

// ========== Team Directory ==========

model Employee {
  id            String   @id @default(cuid())
  
  discordId     String?  @unique
  email         String?  @unique
  name          String
  nickname      String?
  
  department    String   // content-it, content-ev, revenue, production, creative, dev, management
  jobTitle      String?
  role          String   @default("member") // admin, manager, lead, member
  
  phone         String?
  lineId        String?
  profileImage  String?
  
  managerId     String?  // Employee ID of manager
  // startDate     DateTime?  // TODO: Add via Vercel DB dashboard
  // birthDate     DateTime?  // TODO: Add via Vercel DB dashboard
  
  salary        Float?   // เงินเดือน (ไม่แสดงทั่วไป)
  bankAccount   String?  // เลขบัญชี
  bankName      String?
  
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([department])
  @@index([isActive])
}

// ========== Timesheet / Attendance ==========

model Attendance {
  id           String   @id @default(cuid())
  
  employeeId   String
  employeeName String
  date         DateTime
  
  checkIn      DateTime?
  checkOut     DateTime?
  
  workType     String   @default("office") // office, wfh, field, leave
  location     String?  // สถานที่ (กรณี field work)
  
  totalHours   Float?
  otHours      Float?
  
  // Location Verification (Check-in)
  checkInLat       Float?
  checkInLng       Float?
  checkInAccuracy  Float?    // GPS accuracy in meters
  checkInIp        String?
  checkInDistance  Float?    // Distance from office in km
  
  // Location Verification (Check-out)
  checkOutLat      Float?
  checkOutLng      Float?
  checkOutIp       String?
  
  // Location Status
  locationStatus   String?   // verified, suspicious, remote, unavailable
  
  notes        String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([locationStatus])
}

// ========== Asset Management ==========

model Asset {
  id           String   @id @default(cuid())
  
  name         String
  category     String   // camera, lens, mic, tripod, drone, car, laptop, other
  brand        String?
  model        String?
  serialNumber String?
  
  status       String   @default("available") // available, in-use, maintenance, retired
  condition    String   @default("good") // excellent, good, fair, poor
  
  purchaseDate DateTime?
  purchasePrice Float?
  currentValue Float?
  
  location     String?  // ที่เก็บ
  notes        String?
  image        String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  borrowings   AssetBorrowing[]

  @@index([category])
  @@index([status])
}

model AssetBorrowing {
  id           String   @id @default(cuid())
  
  assetId      String
  borrowerId   String   // Employee ID
  borrowerName String
  
  borrowDate   DateTime
  dueDate      DateTime?
  returnDate   DateTime?
  
  purpose      String?  // วัตถุประสงค์
  projectName  String?
  
  status       String   @default("borrowed") // borrowed, returned, overdue
  condition    String?  // สภาพเมื่อคืน
  notes        String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  asset        Asset    @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([borrowerId])
  @@index([status])
}

// ========== Content Calendar ==========

model ContentPlan {
  id           String   @id @default(cuid())
  
  title        String
  site         String   // imod, imoddrive
  category     String?
  
  plannedDate  DateTime
  publishedDate DateTime?
  
  assigneeId   String?
  assigneeName String?
  
  type         String   @default("article") // article, video, review, news
  status       String   @default("planned") // planned, writing, editing, scheduled, published, cancelled
  
  sourceUrl    String?
  draftUrl     String?
  publishedUrl String?
  
  priority     String   @default("normal") // low, normal, high, urgent
  notes        String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([site])
  @@index([plannedDate])
  @@index([status])
  @@index([assigneeId])
}

// ========== HR System (Developed by พี่อาย) ==========

// Leave Balance - วันลาคงเหลือของแต่ละคน
model LeaveBalance {
  id           String   @id @default(cuid())
  
  employeeId   String   // Discord ID or email
  employeeName String
  year         Int      @default(2026)
  
  // วันลาที่ได้รับ (quota) - ตาม requirement พี่อาย
  sickLeaveQuota       Int @default(30)   // ลาป่วย 30 วัน/ปี
  personalLeaveQuota   Int @default(5)    // ลากิจ 5 วัน/ปี
  annualLeaveQuota     Int @default(6)    // ลาพักร้อน 6 วัน/ปี (ต้องทำงานครบ 1 ปี)
  weddingLeaveQuota    Int @default(3)    // ลาแต่งงาน 3 วัน (ใช้ได้ 1 ครั้งตลอดอายุงาน)
  ordinationLeaveQuota Int @default(15)   // ลาบวช 15 วัน (ใช้ได้ 1 ครั้ง)
  childSickLeaveQuota  Int @default(3)    // ลาบุตรป่วย 3 วัน/ปี
  
  // วันลาที่ใช้ไป
  sickLeaveUsed        Int @default(0)
  personalLeaveUsed    Int @default(0)
  annualLeaveUsed      Int @default(0)
  weddingLeaveUsed     Int @default(0)
  ordinationLeaveUsed  Int @default(0)
  childSickLeaveUsed   Int @default(0)
  
  // Flag สำหรับลาครั้งเดียว
  hasUsedWeddingLeave    Boolean @default(false)
  hasUsedOrdinationLeave Boolean @default(false)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, year])
  @@index([employeeId])
}

// Leave Request - คำขอลา
model LeaveRequest {
  id           String   @id @default(cuid())
  
  employeeId   String   // Discord ID or email
  employeeName String
  department   String?
  
  // sick, personal, annual, wedding, ordination, childSick
  leaveType    String   
  startDate    DateTime
  endDate      DateTime
  totalDays    Float    // รองรับลาครึ่งวัน (0.5)
  
  reason       String
  attachment   String?  // URL to medical certificate (required if sick > 3 days)
  
  // ฟิลด์ใหม่ตาม requirement
  isEmergency       Boolean @default(false)  // ลาฉุกเฉินหรือไม่
  consecutiveDays   Int     @default(1)      // จำนวนวันติดต่อกัน
  requiresDocument  Boolean @default(false)  // ต้องแนบเอกสารหรือไม่
  
  status       String   @default("pending") // pending, approved, rejected, cancelled
  approvedBy   String?
  approverName String?
  approvedAt   DateTime?
  rejectReason String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

// Overtime Request - คำขอ OT (Pre-approval required!)
model OvertimeRequest {
  id           String   @id @default(cuid())
  
  employeeId   String
  employeeName String
  department   String?
  
  date         DateTime
  startTime    String   // เวลาเริ่ม OT (e.g., "18:00")
  endTime      String   // เวลาสิ้นสุด (e.g., "21:00")
  plannedHours Float    // ชั่วโมงที่ขอ
  actualHours  Float?   // ชั่วโมงจริง (หลังทำงาน)
  breakMinutes Int      @default(0)  // เวลาพักส่วนตัว (นาที)
  
  // OT Type & Multiplier
  otType       String   @default("normal") // normal (1.5x), holiday (2x)
  multiplier   Float    @default(1.5)      // 1.5x วันปกติ, 2.0x วันหยุด
  isHoliday    Boolean  @default(false)    // เสาร์-อาทิตย์ หรือนักขัตฤกษ์
  
  reason       String
  projectName  String?  // ชื่องาน/โปรเจค
  
  // OT นอกสถานที่
  isOffsite    Boolean  @default(false)
  location     String?
  
  // Pre-approval workflow (REQUIRED!)
  preApproved     Boolean   @default(false)
  preApprovedBy   String?
  preApprovedAt   DateTime?
  
  // Final status
  status       String   @default("pending") // pending, pre-approved, completed, rejected, cancelled
  approvedBy   String?
  approverName String?
  approvedAt   DateTime?
  rejectReason String?
  
  // หัวหน้าปรับชั่วโมง (กรณี offsite)
  adjustedHours Float?
  adjustedNote  String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([date])
}

// Allowance Request - คำขอเบี้ยเลี้ยง
model AllowanceRequest {
  id            String   @id @default(cuid())
  
  employeeId    String
  employeeName  String
  department    String?
  
  // ประเภทพื้นที่ปฏิบัติงาน
  locationType  String   @default("local") // local (200), domestic (400), international (800)
  dailyRate     Float    @default(200)     // อัตราต่อวัน (บาท)
  
  // วันที่
  startDate     DateTime
  endDate       DateTime
  workDays      Int      // วันปฏิบัติงานจริง (นับเบี้ยเลี้ยง)
  travelDays    Int      @default(0)       // วันเดินทาง (ไม่นับเบี้ยเลี้ยง)
  totalAmount   Float    // workDays * dailyRate
  
  // รายละเอียด
  projectName   String   // ชื่องาน (ถ่ายทำ/จัดงาน/ประชุม)
  destination   String   // สถานที่ปฏิบัติงาน
  description   String?  // รายละเอียดเพิ่มเติม
  
  // ขอ OFF DAY จากวันเดินทาง
  requestOffDay Boolean  @default(false)
  offDayStatus  String?  // pending, approved, rejected
  
  status        String   @default("pending") // pending, approved, rejected, cancelled
  approvedBy    String?
  approverName  String?
  approvedAt    DateTime?
  rejectReason  String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

// Late Count Tracking - นับสถิติมาสาย
model LateRecord {
  id           String   @id @default(cuid())
  
  employeeId   String
  employeeName String
  
  date         DateTime
  checkInTime  DateTime
  minutesLate  Int      // จำนวนนาทีที่สาย (หลัง 09:15)
  
  // Warning issued
  warningIssued  Boolean  @default(false)
  warningIssuedAt DateTime?
  
  createdAt    DateTime @default(now())

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Monthly Late Summary - สรุปมาสายรายเดือน
model LateSummary {
  id           String   @id @default(cuid())
  
  employeeId   String
  employeeName String
  
  year         Int
  month        Int      // 1-12
  
  lateCount    Int      @default(0)  // จำนวนครั้งที่มาสาย
  totalMinutes Int      @default(0)  // รวมนาทีที่สาย
  
  // Warning เมื่อครบ 3 ครั้ง
  warningAt    DateTime?
  warningTo    String?   // ส่งถึงใคร (HR/หัวหน้า)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, year, month])
  @@index([employeeId])
}

// Calendar Events - กิจกรรมในปฏิทิน
model CalendarEvent {
  id           String   @id @default(cuid())
  
  title        String
  date         DateTime
  endDate      DateTime?
  time         String?
  type         String   @default("event") // meeting, shooting, deadline, event
  location     String?
  attendees    String[] // Array of names
  description  String?
  
  createdBy    String?  // User ID who created
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([type])
}

// ========== NEV Database v1.0.0-beta.1 ==========
// เพิ่มเมื่อ: 2026-03-11
// Developer: AJ White (Lucus #008)

// NEV Brand - แบรนด์รถยนต์
model NevBrand {
  id           String   @id @default(cuid())
  
  name         String   @unique  // BYD, Tesla, MG
  nameTh       String?           // ชื่อภาษาไทย
  slug         String   @unique  // byd, tesla, mg
  
  logoUrl      String?
  country      String?           // China, USA, Thailand
  website      String?
  
  // Stats
  totalModels  Int      @default(0)
  
  isActive     Boolean  @default(true)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  models       NevModel[]

  @@index([isActive])
}

// NEV Model - รุ่นรถ (เช่น BYD Dolphin, Tesla Model 3)
model NevModel {
  id           String   @id @default(cuid())
  
  brandId      String
  
  name         String            // Dolphin, Model 3
  nameTh       String?
  slug         String   @unique  // byd-dolphin, tesla-model-3
  fullName     String?           // BYD Dolphin Dynamic
  
  year         Int?              // Model Year (2026)
  
  // Vehicle Type
  bodyType     String?           // Hatchback, Sedan, SUV, MPV, Pickup
  segment      String?           // A, B, C, D, E
  seats        Int?              // 5, 7
  
  // Powertrain
  powertrain   String            // BEV, PHEV, HEV, REEV, ICE
  
  // Assembly
  assembly     String?           // CKD, CBU
  madeIn       String?           // Thailand, China
  
  // Media
  imageUrl     String?
  galleryUrls  String[]          // Array of image URLs
  youtubeId    String?           // YouTube video ID
  
  // Description
  overview     String?           // คำอธิบายรวม
  highlights   String[]          // จุดเด่น
  
  // Status
  isActive     Boolean  @default(true)
  isNewModel   Boolean  @default(false)  // รุ่นใหม่
  launchDate   DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  brand        NevBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  variants     NevVariant[]

  @@index([brandId])
  @@index([powertrain])
  @@index([isActive])
}

// NEV Variant - รุ่นย่อย (เช่น Dolphin Dynamic, Dolphin Extended Range)
model NevVariant {
  id           String   @id @default(cuid())
  
  modelId      String
  
  name         String            // Dynamic, Extended Range, Performance AWD
  fullName     String            // BYD Dolphin Dynamic
  slug         String   @unique
  
  // Price
  priceBaht    Int?              // ราคา (บาท)
  priceNote    String?           // หมายเหตุราคา
  
  // Battery & Range
  batteryKwh   Float?            // ความจุแบตเตอรี่ (kWh)
  rangeKm      Int?              // ระยะทาง (กม.)
  rangeStandard String?          // CLTC, WLTP, NEDC
  
  // Motor
  motorCount   Int      @default(1)  // จำนวนมอเตอร์
  motorKw      Float?            // กำลังมอเตอร์รวม (kW)
  motorHp      Int?              // แรงม้า
  torqueNm     Int?              // แรงบิด (Nm)
  
  // Performance
  topSpeedKmh  Int?              // ความเร็วสูงสุด (km/h)
  accel0100    Float?            // 0-100 km/h (วินาที)
  
  // Drivetrain
  drivetrain   String?           // FWD, RWD, AWD
  
  // Charging
  dcChargeKw   Float?            // DC Fast Charge (kW)
  dcChargeMin  Int?              // 10-80% (นาที)
  acChargeKw   Float?            // AC Charge (kW)
  chargePort   String?           // CCS2, GB/T, Tesla
  
  // PHEV/HEV specific
  engineCc     Int?              // ความจุเครื่องยนต์ (cc)
  engineHp     Int?              // แรงม้าเครื่องยนต์
  combinedHp   Int?              // แรงม้ารวม
  fuelTankL    Int?              // ความจุถังน้ำมัน (L)
  fuelConsumption Float?         // อัตราสิ้นเปลือง (km/L)
  
  // Dimensions
  lengthMm     Int?
  widthMm      Int?
  heightMm     Int?
  wheelbaseMm  Int?
  groundClearanceMm Int?
  curbWeightKg Int?
  grossWeightKg Int?
  trunkLitres  Int?
  
  // Warranty
  warrantyVehicle   String?      // 5 ปี / 150,000 กม.
  warrantyBattery   String?      // 8 ปี / 160,000 กม.
  
  // Features (stored as JSON)
  features     String?           // JSON: { "adas": [...], "safety": [...], "comfort": [...] }
  
  // V2L / V2G
  hasV2l       Boolean  @default(false)
  v2lKw        Float?
  hasV2g       Boolean  @default(false)
  
  // Status
  isActive     Boolean  @default(true)
  isBestSeller Boolean  @default(false)
  
  // Data source tracking
  dataSource   String?           // excel, manual, api
  lastVerified DateTime?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  model        NevModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([priceBaht])
  @@index([rangeKm])
  @@index([isActive])
}

// NEV Data Version - ติดตามการอัปเดตข้อมูล
model NevDataVersion {
  id           String   @id @default(cuid())
  
  version      String            // 1.0.0-beta.1
  releaseNotes String?           // What changed
  
  totalBrands  Int      @default(0)
  totalModels  Int      @default(0)
  totalVariants Int     @default(0)
  
  importedFrom String?           // excel, google-sheets, api
  importedBy   String?           // User ID
  importedAt   DateTime @default(now())
  
  createdAt    DateTime @default(now())

  @@index([version])
}

// NEV Audit Log - ติดตามการแก้ไขข้อมูล
model NevAuditLog {
  id           String   @id @default(cuid())
  
  userId       String?
  userName     String?
  
  action       String            // create, update, delete, import
  targetType   String            // brand, model, variant
  targetId     String
  targetName   String?
  
  changes      String?           // JSON: { field: { old: x, new: y } }
  
  createdAt    DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}
