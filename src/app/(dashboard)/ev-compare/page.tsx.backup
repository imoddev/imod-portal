"use client";

import { useState, useRef } from "react";
import { Download, Plus, X, Search, GripVertical, Settings } from "lucide-react";

interface EVSpec {
  id: string;
  name: string;
  brand: string;
  model: string;
  price: number;
  image?: string;
  specs: {
    [key: string]: string | number;
  };
}

interface SpecField {
  key: string;
  label: string;
  enabled: boolean;
}

