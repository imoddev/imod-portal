--- Fix "Failed to send request" error และเพิ่ม Autocomplete สำหรับ Brand/Model ---

สรุปการแก้ไข:
1. ✅ แก้ไข error handling ใน handleAddNewCarSubmit
2. ✅ เพิ่ม trim() สำหรับ input fields
3. ✅ เพิ่ม autocomplete dropdown สำหรับ Brand + Model
4. ✅ ป้องกันการสะกดผิด (เลือกจาก dropdown เท่านั้น)

## Implementation Steps:

### 1. เพิ่ม handler functions (หลังบรรทัด ~545):

```typescript
  // Handle brand input change (autocomplete)
  const handleBrandInputChange = (value: string) => {
    setNewCarForm({ ...newCarForm, brand: value, model: '', variant: '' });
    
    if (value.trim().length > 0) {
      const filtered = allBrands.filter(b => 
        b.name.toLowerCase().includes(value.toLowerCase()) ||
        (b.nameTh && b.nameTh.includes(value))
      );
      setFilteredBrands(filtered);
      setShowBrandSuggestions(true);
    } else {
      setFilteredBrands(allBrands);
      setShowBrandSuggestions(false);
    }
  };
  
  // Handle brand selection from dropdown
  const handleBrandSelect = (brand: typeof allBrands[0]) => {
    setNewCarForm({ ...newCarForm, brand: brand.name, model: '', variant: '' });
    setShowBrandSuggestions(false);
    
    // Filter models by brand
    const brandModels = allModels.filter(m => m.brand.name === brand.name);
    setFilteredModels(brandModels);
  };
  
  // Handle model input change (autocomplete)
  const handleModelInputChange = (value: string) => {
    setNewCarForm({ ...newCarForm, model: value, variant: '' });
    
    if (value.trim().length > 0) {
      const filtered = filteredModels.filter(m => 
        m.name.toLowerCase().includes(value.toLowerCase()) ||
        (m.nameTh && m.nameTh.includes(value))
      );
      setFilteredModels(filtered);
      setShowModelSuggestions(true);
    } else {
      const brandModels = allModels.filter(m => m.brand.name === newCarForm.brand);
      setFilteredModels(brandModels);
      setShowModelSuggestions(false);
    }
  };
  
  // Handle model selection from dropdown
  const handleModelSelect = (model: typeof allModels[0]) => {
    setNewCarForm({ ...newCarForm, model: model.name });
    setShowModelSuggestions(false);
  };
```

### 2. แทนที่ Brand input field (บรรทัด ~1049):

```tsx
{/* Brand Field - Autocomplete */}
<div>
  <label className="block text-sm font-medium mb-2">
    แบรนด์ (Brand) <span className="text-red-500">*</span>
  </label>
  <div className="relative">
    <input
      type="text"
      value={newCarForm.brand}
      onChange={(e) => handleBrandInputChange(e.target.value)}
